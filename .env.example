# ============================================================================
# KNOWNET X - Environment Configuration
# ============================================================================
# Copy this file to .env and .env.local and fill in your actual values

# ============================================================================
# FRONTEND (.env.local)
# ============================================================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# OpenAI Configuration
NEXT_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here

# Auth Configuration
NEXT_PUBLIC_AUTH_PROVIDER=custom

# Feature Flags
NEXT_PUBLIC_ENABLE_RESEARCH=true
NEXT_PUBLIC_ENABLE_GRAPH=true
NEXT_PUBLIC_ENABLE_COLLABORATION=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=

# ============================================================================
# BACKEND (.env)
# ============================================================================

# Application
APP_NAME=KnowNet X
APP_ENV=development
DEBUG=True
SECRET_KEY=change-me-in-production-with-strong-random-string

# Database
DATABASE_URL=postgresql://knownet:knownet_password@localhost:5432/knownet_db
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Authentication
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=

# OpenAI
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# LangGraph
LANGGRAPH_API_KEY=
LANGGRAPH_ENDPOINT=

# Vector Database
VECTOR_DB_TYPE=chroma
VECTOR_DB_PATH=./data/chroma
# Alternative: Pinecone
# PINECONE_API_KEY=
# PINECONE_ENVIRONMENT=
# PINECONE_INDEX_NAME=knownet

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# Email
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@knownet.ai
MAIL_TLS=true

# Security
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# MFA
MFA_ISSUER=KnowNet X
MFA_QR_CODE_SIZE=300

# Encryption
ENCRYPTION_KEY=your-encryption-key-change-in-production

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/knownet.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# AWS (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# File Upload
MAX_UPLOAD_SIZE=52428800  # 50MB
ALLOWED_UPLOAD_TYPES=["pdf", "docx", "txt", "md", "csv", "json"]
UPLOAD_DIRECTORY=./uploads

# ============================================================================
# DOCKER COMPOSE
# ============================================================================

# PostgreSQL
POSTGRES_USER=knownet
POSTGRES_PASSWORD=knownet_password
POSTGRES_DB=knownet_db
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Celery
CELERY_WORKERS=4

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Production URLs
PRODUCTION_API_URL=https://api.knownet.ai
PRODUCTION_FRONTEND_URL=https://knownet.ai

# CDN
CDN_URL=https://cdn.knownet.ai

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
